        </div>
        ${p.tag?`<span class="tag">${p.tag}</span>`:''}
        <p class="mi-desc">${p.desc}</p>
        <button class="btn-add" onclick="addToCart('${p.name.replace(/'/g,"\\'")}','${p.price}')">+ Add</button>
      </div>
    </div>
  `).join('');
}
function filterMenu(filter, btn){
  document.querySelectorAll('.mtab').forEach(t=>t.classList.remove('active'));
  btn.classList.add('active');
  renderMenu(filter);
}

/* ═══ CART ═══ */
function addToCart(name,price){
  const ex = cart.find(i=>i.name===name);
  if(ex) ex.qty++;
  else cart.push({name,price,qty:1});
  updateCart();
}
function updateQty(name,d){
  const item = cart.find(i=>i.name===name);
  if(!item) return;
  item.qty += d;
  if(item.qty<=0) cart = cart.filter(i=>i.name!==name);
  updateCart();
}
function clearCart(){ cart=[]; updateCart(); }
function updateCart(){
  const count = cart.reduce((s,i)=>s+i.qty,0);
  document.getElementById('cartCount').textContent = count;
  const empty = cart.length===0;
  document.getElementById('cartEmpty').style.display = empty?'block':'none';
  document.getElementById('cartList').style.display = empty?'none':'flex';
  document.getElementById('cartTotalRow').style.display = empty?'none':'flex';
  document.getElementById('cartForm').style.display = empty?'none':'flex';
  if(!empty){
    document.getElementById('cartList').innerHTML = cart.map(item=>`
      <div class="cart-row">
        <span class="cart-row-name">${item.name}</span>
        <div class="cart-qbtns">
          <button class="qbtn" onclick="updateQty('${item.name.replace(/'/g,"\\'")}', -1)">−</button>
          <span>${item.qty}</span>
          <button class="qbtn" onclick="updateQty('${item.name.replace(/'/g,"\\'")}', 1)">+</button>
        </div>
      </div>
    `).join('');
    const total = cart.reduce((s,i)=>s+parseFloat(i.price.replace('£',''))*i.qty,0);
    document.getElementById('cartTotalAmt').textContent = '£'+total.toFixed(2);
  }
}
function placeOrder(){
  if(!cart.length) return;
  const name = document.getElementById('oName').value;
  const phone = document.getElementById('oPhone').value;
  const lines = cart.map(i=>`- ${i.name} x${i.qty}`).join('\n');
  const text = `Hello Mango Mania,\nI would like to place an order.\n\nOrder Details:\n${lines}\n\nCustomer Name: ${name||'Not provided'}\nPhone Number: ${phone||'Not provided'}\n\nPlease confirm my order.`;
  window.open(`https://api.whatsapp.com/send/?phone=447748460463&text=${encodeURIComponent(text)}&type=phone_number&app_absent=0`,'_blank');
  clearCart();
  document.getElementById('oName').value='';
  document.getElementById('oPhone').value='';
}

