/* ═══ MENU ═══ */
function renderMenu(filter){
  const items = filter==='all' ? PRODUCTS : PRODUCTS.filter(p=>p.cat===filter);
  document.getElementById('menuList').innerHTML = items.map(p=>`
    <div class="menu-item" role="listitem">
