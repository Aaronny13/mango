/* ═══ CONTACT FORM ═══ */
function submitForm(e){
  e.preventDefault();
  let ok = true;
  const fn=document.getElementById('fn'),fe=document.getElementById('fe'),fs=document.getElementById('fs'),fm=document.getElementById('fm');
  document.querySelectorAll('.ferr').forEach(el=>el.classList.remove('show'));
  if(!fn.value.trim()||fn.value.trim().length<2){document.getElementById('fn-err').classList.add('show');ok=false;}
  if(!fe.value.trim()||!fe.value.includes('@')){document.getElementById('fe-err').classList.add('show');ok=false;}
  if(!fs.value.trim()||fs.value.trim().length<2){document.getElementById('fs-err').classList.add('show');ok=false;}
  if(!fm.value.trim()||fm.value.trim().length<10){document.getElementById('fm-err').classList.add('show');ok=false;}
  if(!ok) return;
  const prod = document.getElementById('fprod').value;
  const text = [
    `Name: ${fn.value}`,
    `Email: ${fe.value}`,
    `Phone: ${document.getElementById('fp').value||'Not provided'}`,
    `Subject: ${fs.value}`,
    prod?`Product Interested In: ${prod}`:'',
    `Message:\n${fm.value}`,
    `\nPlease contact me regarding my enquiry.`
  ].filter(Boolean).join('\n');
  window.open(`https://api.whatsapp.com/send/?phone=447748460463&text=${encodeURIComponent(text)}&type=phone_number&app_absent=0`,'_blank');
  e.target.reset();
}
</script>
